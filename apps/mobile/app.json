{
  "expo": {
    "name": "NexaAi",
    "slug": "nexaai-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "nexaai",
    "userInterfaceStyle": "automatic",
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    }
  }
}
