# Supabase (Publishable Key: public, for client)
# Dashboard > Settings > API Keys
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxx
EXPO_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxx

# Supabase (Secret Key: private, only for Edge Functions and server actions)
SUPABASE_SECRET_KEY=sb_secret_xxxxx

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# DeepSeek AI (primary LLM)
DEEPSEEK_API_KEY=sk-xxxxx

# Mistral (EU-hosted fallback for DSGVO-sensitive tasks)
MISTRAL_API_KEY=xxxxx

# Node
NODE_ENV=development
